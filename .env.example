# Copy this file to .env and fill in your values

# Your Windows PC IP address (check with ipconfig on Windows)
OLLAMA_BASE_URL=http://192.168.1.XXX:11434

# Models (must be pulled on the Windows PC first)
LLM_MODEL=llama3.1:8b
EMBED_MODEL=nomic-embed-text

# PDF folder on this laptop
PDF_BASE=/home/youruser/Documents/pdf

# Where ChromaDB will store the vector index
CHROMA_PATH=./chroma_db

# Number of chunks to retrieve per query
TOP_K=5
