# Copy this file to .env and fill in your values

# Your Windows PC IP address (check with ipconfig on Windows)
OLLAMA_LLM_URL=http://192.168.1.XXX:11434
OLLAMA_EMBED_URL=http://localhost:11434

# Models (must be pulled on the Windows PC first)
LLM_MODEL=llama3.1:8b
EMBED_MODEL=nomic-embed-text

# PDF folder on this laptop
PDF_BASE=/home/youruser/Documents/pdf

# Where ChromaDB will store the vector index
CHROMA_PATH=/absolute/path/to/rag-pdf/chroma_db

# Number of chunks to retrieve per query
TOP_K=5

# Default context window (tokens). 4096 works for most models.
OLLAMA_NUM_CTX=4096

# Per-model overrides — JSON dict. Use for models with VRAM constraints.
# OLLAMA_NUM_CTX_MAP={"hf.co/unsloth/NVIDIA-Nemotron-3-Nano-4B-GGUF:Q4_K_M": 1024}
